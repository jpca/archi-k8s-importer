<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.core.runtime.preferences">
      <initializer
            class="fr.jpca.archi.k8simporter.PreferenceInitializer">
      </initializer>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            categoryId="org.eclipse.ui.category.file"
            id="fr.jpca.archi.k8simporter.importCommand"
            name="Import K8s Namespace">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="fr.jpca.archi.k8simporter.K8sImportHandler"
            commandId="fr.jpca.archi.k8simporter.importCommand">
         <enabledWhen>
            <reference
                  definitionId="com.archimatetool.modelEnabled">
            </reference>
         </enabledWhen>
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:import_menu?endof=import_ext">
         <command
               id="fr.jpca.archi.k8simporter.importMenu"
               commandId="fr.jpca.archi.k8simporter.importCommand"
               label="Import K8s Namespace..."
               style="push">
         </command>
      </menuContribution>
   </extension>

</plugin>
